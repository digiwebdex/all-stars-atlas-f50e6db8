# Seven Trip — Frontend Environment Variables
# Copy this file to .env and update the values

# Backend API Base URL (required)
# Development: http://localhost:3001/api
# Production:  https://api.seventrip.com.bd/api
VITE_API_BASE_URL=http://localhost:3001/api

# Google Drive Integration (optional)
# Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Enable "Google Drive API" in your Google Cloud project
# Add your domain to Authorized JavaScript origins
VITE_GOOGLE_CLIENT_ID=